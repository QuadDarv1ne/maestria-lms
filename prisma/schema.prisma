generator client {
  provider = "prisma-client-js"
}

// Current provider: postgresql (default for production)
// Change to "mysql" or "sqlite" as needed
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ AUTH (NextAuth.js) ============

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  image         String?
  role          String    @default("student") // student, teacher, admin
  bio           String?
  phone         String?
  twoFactorEnabled  Boolean @default(false)
  twoFactorSecret   String?
  emailVerified     DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  enrollments   Enrollment[]
  reviews       Review[]
  certificates  Certificate[]
  payments      Payment[]
  progress      Progress[]
  teacherCourses Course[]  @relation("TeacherCourses")
  notifications  Notification[]
  gradedSubmissions AssignmentSubmission[] @relation("GradedSubmissions")
  assignmentSubmissions AssignmentSubmission[]
  articles      Article[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@index([identifier])
}

// ============ COURSES ============

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  color       String?
  sortOrder   Int      @default(0)
  courses     Course[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String
  shortDesc   String?
  image       String?
  price       Float    @default(0)
  oldPrice    Float?
  currency    String   @default("RUB")
  level       String   @default("beginner") // beginner, intermediate, advanced
  duration    String?  // e.g. "8 недель"
  language    String   @default("ru")
  isPublished Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  hasCertificate Boolean @default(true)
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  studentCount Int     @default(0)
  tags        String?  // comma-separated
  requirements String? // JSON array string
  whatYouLearn String? // JSON array string
  startDate   DateTime?
  endDate     DateTime?
  visibility  String   @default("public") // public, private, unlisted
  maxStudents Int?
  prerequisites String? // JSON array of course IDs

  categoryId  String?
  category    Category?  @relation(fields: [categoryId], references: [id])
  teacherId   String?
  teacher     User?      @relation("TeacherCourses", fields: [teacherId], references: [id])
  modules     Module[]
  enrollments Enrollment[]
  reviews     Review[]
  payments    Payment[]
  certificates Certificate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPublished])
  @@index([isFeatured, createdAt])
  @@index([categoryId])
  @@index([teacherId])
}

model Module {
  id          String   @id @default(uuid())
  title       String
  description String?
  sortOrder   Int      @default(0)
  courseId     String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     Lesson[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId])
}

model Lesson {
  id          String   @id @default(uuid())
  title       String
  type        String   @default("video") // video, text, quiz, coding, assignment
  content     String?  // HTML/Markdown content
  videoUrl    String?
  duration    Int      @default(0) // minutes
  sortOrder   Int      @default(0)
  isFree      Boolean  @default(false)
  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  assignments Assignment[]
  progress    Progress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([moduleId])
}

model Assignment {
  id          String   @id @default(uuid())
  title       String
  description String
  type        String   @default("quiz") // quiz, coding, text, matching, ordering, file_upload, essay, drag_drop
  options     String?  // JSON: quiz options, matching pairs, ordering items, etc.
  correctAnswer String?
  points      Int      @default(10)
  maxAttempts Int      @default(0) // 0 = unlimited attempts
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  submissions AssignmentSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lessonId])
}

model AssignmentSubmission {
  id          String   @id @default(uuid())
  assignmentId String
  userId      String
  answer      String   // JSON or text: student's answer
  score       Int?
  maxScore    Int      @default(100)
  grade       String?  // grade letter or feedback
  feedback    String?  // teacher feedback
  status      String   @default("submitted") // draft, submitted, graded, failed
  submittedAt DateTime @default(now())
  gradedAt    DateTime?
  gradedBy    String?  // teacher ID
  grader      User?    @relation("GradedSubmissions", fields: [gradedBy], references: [id])

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assignmentId, userId])
  @@index([userId, status])
  @@index([assignmentId])
}

// ============ ENROLLMENT & PROGRESS ============

model Enrollment {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  status    String   @default("active") // active, completed, cancelled
  progress  Float    @default(0) // percentage 0-100
  enrolledAt DateTime @default(now())
  completedAt DateTime?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])

  @@index([courseId])
  @@index([status])
}

model Progress {
  id          String   @id @default(uuid())
  userId      String
  lessonId    String
  completed   Boolean  @default(false)
  score       Int?
  timeSpent   Int      @default(0) // seconds
  lastAccessed DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, completed])
}

// ============ REVIEWS ============

model Review {
  id        String   @id @default(uuid())
  rating    Int      // 1-5
  comment   String?
  userId    String
  courseId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
  @@index([courseId, createdAt])
}

// ============ PAYMENTS ============

model Payment {
  id              String   @id @default(uuid())
  userId          String
  courseId        String
  amount          Float
  currency        String   @default("RUB")
  status          String   @default("pending") // pending, completed, failed, refunded
  paymentMethod   String   // sbp, yookassa, tinkoff, card
  paymentProvider String?
  transactionId   String?
  paymentData     String?  // JSON: additional payment data
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([courseId])
  @@index([status])
  @@index([transactionId])
  @@index([userId, courseId, status])
}

// ============ CERTIFICATES ============

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   // enrollment, completion, achievement, review, system, payment
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model Certificate {
  id          String   @id @default(uuid())
  userId      String
  courseId    String
  certificateNumber String @unique
  issuedAt    DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

// ============ BLOG / ARTICLES ============

model Article {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  content     String   // HTML/Markdown content
  excerpt     String?  // Short preview text
  image       String?  // Cover image URL
  category    String   // development, testing, databases, ai, 3d-modeling, security, devops, career
  tags        String?  // comma-separated tags
  readTime    Int      @default(5) // estimated reading time in minutes
  views       Int      @default(0)
  isPublished Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished])
  @@index([category])
  @@index([authorId])
  @@index([isFeatured, createdAt])
  @@index([slug])
}
