# ═══════════════════════════════════════════════════
# Maestria LMS — Environment Configuration
# Auto-generated by setup.js
# ═══════════════════════════════════════════════════

# ─── Database ───
# Supported: sqlite, postgresql, mongodb
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:./prisma/data.db

# ─── NextAuth ───
NEXTAUTH_URL=http://localhost:3000
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=

# ─── CDN & Assets ───
# Replace with your actual CDN URL in production
NEXT_PUBLIC_CDN_URL=
NEXT_PUBLIC_SITE_URL=

# ─── S3 Storage (optional) ───
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_BUCKET_NAME=
S3_REGION=auto

# ─── Email (Resend) ───
RESEND_API_KEY=
EMAIL_FROM=Maestria LMS <noreply@maestria.edu>

# ─── Redis (optional) ───
REDIS_URL=

# ─── Logging ───
# Supported: error, warn, info, debug
LOG_LEVEL=info

# ─── Payment Webhook ───
# HMAC secret for payment provider webhook verification
PAYMENT_WEBHOOK_SECRET=

ALLOW_SEED_DATA=false
