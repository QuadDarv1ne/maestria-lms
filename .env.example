# ========================================
# Database Configuration
# ========================================
# Supported providers: postgresql, mysql, sqlite
# Default: postgresql (recommended for production)

DATABASE_PROVIDER=postgresql

# SQLite (development/testing)
# DATABASE_URL="file:./prisma/data.db"

# PostgreSQL (production)
# Format: postgresql://user:password@host:port/database?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/maestria_lms?schema=public"

# MySQL (alternative production option)
# Format: mysql://user:password@host:port/database
# DATABASE_URL="mysql://root:password@localhost:3306/maestria_lms"

# ========================================
# NextAuth Configuration
# ========================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=<generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))">

# ========================================
# Site Configuration
# ========================================
NEXT_PUBLIC_SITE_URL=https://maestria.edu

# ========================================
# CDN (optional)
# ========================================
NEXT_PUBLIC_CDN_URL=https://ui3adtb308.a.trbcdn.net

# ========================================
# S3 Storage (optional)
# ========================================
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
S3_BUCKET=maestria-lms
S3_REGION=auto

# ========================================
# Seed Data (development only)
# ========================================
# Set to true to allow /api/seed endpoint in development
ALLOW_SEED_DATA=true
