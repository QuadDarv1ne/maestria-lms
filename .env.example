# ═══════════════════════════════════════════════════
# Maestria LMS — Environment Configuration
# Auto-generated by setup.js
# ═══════════════════════════════════════════════════

# ─── Database ───
# Supported: sqlite, postgresql, mongodb
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:./prisma/data.db

# ─── NextAuth ───
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32 (min 32 bytes required in production)
NEXTAUTH_SECRET=

# ─── CDN & Assets ───
NEXT_PUBLIC_CDN_URL=https://ui3adtb308.a.trbcdn.net
NEXT_PUBLIC_SITE_URL=https://maestria.edu

# ─── S3 Storage (optional) ───
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=https://s3c3.001.gpucloud.ru
S3_BUCKET_NAME=maestria-lms
S3_REGION=auto

# ─── Email (Resend) ───
RESEND_API_KEY=
EMAIL_FROM=noreply@maestria.edu

# ─── Redis (optional, for rate limiting) ───
REDIS_URL=redis://localhost:6379

# ─── Payment Webhook ───
PAYMENT_WEBHOOK_SECRET=

# ─── YooKassa (ЮKassa) ───
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ─── Logging ───
LOG_LEVEL=info

# ─── Development ───
# WARNING: Set to false in production. Allows database seeding via /api/seed.
ALLOW_SEED_DATA=false

# ─── Seed Passwords (optional, auto-generated if not set) ───
SEED_ADMIN_PASSWORD=
SEED_TEACHER_PASSWORD=
