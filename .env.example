# Database Configuration
# Supported providers: sqlite, postgresql, mysql, mongodb
# Set DATABASE_PROVIDER to hint the provider (auto-detected from URL if omitted)

# SQLite (default for development)
# DATABASE_PROVIDER=sqlite
# DATABASE_URL=file:./prisma/data.db

# PostgreSQL (recommended for production)
# DATABASE_PROVIDER=postgresql
# DATABASE_URL=postgresql://postgres:password@localhost:5432/maestria_lms?schema=public

# MySQL (alternative for production)
# DATABASE_PROVIDER=mysql
# DATABASE_URL=mysql://root:password@localhost:3306/maestria_lms

# MongoDB (alternative, uses native driver not Prisma)
# DATABASE_PROVIDER=mongodb
# DATABASE_URL=mongodb://root:password@localhost:27017/maestria_lms

# Active configuration (SQLite default)
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:./prisma/data.db

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=<generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))">

# CDN (optional)
NEXT_PUBLIC_CDN_URL=https://ui3adtb308.a.trbcdn.net
NEXT_PUBLIC_SITE_URL=https://maestria.edu

# S3 Storage (optional - leave empty if not using S3)
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
S3_BUCKET=maestria-lms
S3_REGION=auto

# Seed data (set to true to allow /api/seed endpoint in development)
ALLOW_SEED_DATA=true
