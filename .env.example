# Database Configuration
# For SQLite (default):
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:./prisma/data.db

# For PostgreSQL:
# DATABASE_PROVIDER=postgresql
# DATABASE_URL=postgresql://user:password@localhost:5432/maestria

# For MySQL:
# DATABASE_PROVIDER=mysql
# DATABASE_URL=mysql://user:password@localhost:3306/maestria

# For MongoDB:
# DATABASE_PROVIDER=mongodb
# DATABASE_URL=mongodb://localhost:27017/maestria

# NextAuth Configuration
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# S3 Storage (optional - for file uploads)
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Optional: CDN URL
# NEXT_PUBLIC_CDN_URL=https://your-cdn.com

# Optional: Logging level (error | warn | info | debug)
# LOG_LEVEL=info

# Optional: Site URL for SEO
# NEXT_PUBLIC_SITE_URL=https://maestria.edu
